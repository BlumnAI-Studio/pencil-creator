{
  "name": "pencil-design-harness",
  "version": "2.9.0",
  "description": "Pencil Design 품질 하네스 — Case A(WPF→템플릿), Case B(템플릿참고→프로젝트 디자인), Case C(웹→JSON→펜슬 컴포넌트), Case D(DesignMD→펜슬 복제), Case S(컨셉아트→스프라이트 시트), Case W(Pencil→HTML) 평가 · v2.8.0 sprite-animator 도입 · v2.9.0 gpt-image-2 프로바이더 + 실제 영상 동작 분석 입력 소스 + 통합 자산 플레이어",
  "scope": "pencil-design",
  "layers": {
    "knowledge": "harness/knowledge/",
    "agents": "harness/agents/",
    "engine": "harness/engine/"
  },
  "agents": [
    { "name": "design-evaluator", "path": "harness/agents/design-evaluator.md", "scope": "all-cases" },
    { "name": "sprite-animator",  "path": "harness/agents/sprite-animator.md",  "scope": "case-S", "since": "v2.8.0" }
  ],
  "engine_workflows": [
    { "name": "design-journey",        "path": "harness/engine/design-journey.md",         "scope": "all-cases" },
    { "name": "sprite-animation-flow", "path": "harness/engine/sprite-animation-flow.md",  "scope": "case-S", "since": "v2.8.0" },
    { "name": "level-achievement",     "path": "harness/engine/level-achievement-system.md", "scope": "rpg" }
  ],
  "knowledge_docs": [
    { "name": "design-craft",            "path": "harness/knowledge/design-craft.md" },
    { "name": "midi-orchestra",          "path": "harness/knowledge/midi-orchestra.md" },
    { "name": "sprite-animation-craft",  "path": "harness/knowledge/sprite-animation-craft.md", "since": "v2.8.0" }
  ],
  "evaluation": {
    "design": {
      "cases": {
        "A": { "axes": 3, "maxScore": 100, "label": "WPF → Template Enrichment", "target": "design/wpf-animation.pen" },
        "B": { "axes": 3, "maxScore": 100, "label": "Template Ref → Project Design", "target": "projects/design/*.pen" },
        "C": { "axes": 3, "maxScore": 100, "label": "Web Animation → JSON → Pencil Component (Copycat)", "target": "design/json/sample/*.json" },
        "D": { "axes": 3, "maxScore": 100, "label": "DesignMD → Pencil Replication (Tokens/Components/Templates)", "target": "design/design-md.pen" },
        "S": { "axes": 3, "maxScore": 100, "label": "Concept Art → Sprite Sheet (Transparent PNG + Aseprite Hash JSON)", "target": "design/sprite/output/_master/index.json" },
        "W": { "axes": 3, "maxScore": 100, "label": "Pencil → HTML (SVG Realism + WAAPI)" }
      },
      "pipeline_bonus": {
        "A_B": { "multiplier": 1.2, "condition": "both >= 60" },
        "A_W": { "multiplier": 1.2, "condition": "both >= 60" },
        "B_W": { "multiplier": 1.3, "condition": "both >= 60" },
        "C_W": { "multiplier": 1.3, "condition": "both >= 60" },
        "C_B": { "multiplier": 1.2, "condition": "both >= 60" },
        "D_B": { "multiplier": 1.3, "condition": "both >= 60" },
        "D_W": { "multiplier": 1.3, "condition": "both >= 60" },
        "S_W": { "multiplier": 1.3, "condition": "both >= 60" },
        "S_B": { "multiplier": 1.2, "condition": "both >= 60" },
        "A_S": { "multiplier": 1.2, "condition": "both >= 60" },
        "A_B_W": { "multiplier": 1.5, "condition": "all >= 60" },
        "C_B_W": { "multiplier": 1.5, "condition": "all >= 60" },
        "D_B_W": { "multiplier": 1.5, "condition": "all >= 60" },
        "S_B_W": { "multiplier": 1.5, "condition": "all >= 60" }
      },
      "reference": "harness/knowledge/design-craft.md"
    },
    "grades": {
      "A": [80, 100],
      "B": [60, 79],
      "C": [40, 59],
      "D": [0, 39]
    }
  },
  "rpg_system": {
    "enabled": true,
    "max_level": 100,
    "level_state": "harness/logs/level-up/status.json",
    "level_history": "harness/logs/level-up/history.md",
    "achievement_state": "harness/logs/achievements/achievements.json",
    "achievement_history": "harness/logs/achievements/history.md",
    "rules": "harness/engine/level-achievement-system.md",
    "xp_formula": {
      "base": "score * 10",
      "grade_multiplier": { "A": 5, "B": 3, "C": 1, "D": 0.5 },
      "type_multiplier": { "A": 1.2, "B": 1.2, "C": 1.2, "D": 1.2, "S": 1.2, "W": 1.2 }
    }
  },
  "skills": {
    "pencil-design": {
      "path": ".claude/skills/pencil-design/",
      "current_version": "1.5.0",
      "note": "v1.5.0: OpenAI gpt-image-2 이미지 프로바이더 추가 (generate+edit, urllib only)"
    },
    "harness-creator": {
      "path": ".claude/skills/harness-creator/",
      "current_version": "1.0.0"
    },
    "harness-usage": {
      "path": ".claude/skills/harness-usage/",
      "current_version": "2.6.0"
    },
    "video-motion-analysis": {
      "path": ".claude/skills/video-motion-analysis/",
      "current_version": "1.0.0",
      "scope": "case-S-input",
      "note": "실제 영상(YouTube/로컬) 동작 분석 → 스프라이트 모션 키프레임 입력 소스 (Case S 피더)"
    }
  }
}
