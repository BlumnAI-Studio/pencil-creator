<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Idle Breathing" Height="360" Width="320" Background="#0A0F1C">
    <Grid>
        <!-- Character body (chest area scales subtly) -->
        <Grid x:Name="charRoot"
              Width="120" Height="180"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,1.0">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="breathScale" ScaleX="1" ScaleY="1"/>
                    <TranslateTransform x:Name="breathLift" Y="0"/>
                </TransformGroup>
            </Grid.RenderTransform>
            <Ellipse Width="60" Height="60" Fill="#FFE0BD"
                     VerticalAlignment="Top" HorizontalAlignment="Center"/>
            <Rectangle Width="100" Height="100" RadiusX="14" RadiusY="14"
                       Fill="#22D3EE" Margin="0,55,0,0"/>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetName="breathScale"
                                Storyboard.TargetProperty="ScaleY"
                                From="1.0" To="1.04" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="breathScale"
                                Storyboard.TargetProperty="ScaleX"
                                From="1.0" To="1.02" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="breathLift"
                                Storyboard.TargetProperty="Y"
                                From="0" To="-3" Duration="0:0:1.6">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>
    </Grid>
</Window>
