<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Squash and Stretch" Height="320" Width="320" Background="#0A0F1C">
    <Grid>
        <Ellipse x:Name="ball" Width="80" Height="80" Fill="#22D3EE"
                 RenderTransformOrigin="0.5,1.0"
                 HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="scaleT" ScaleX="1" ScaleY="1"/>
                    <TranslateTransform x:Name="translateT" Y="0"/>
                </TransformGroup>
            </Ellipse.RenderTransform>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <!-- Stretch up: tall + thin -->
                            <DoubleAnimation Storyboard.TargetName="translateT"
                                Storyboard.TargetProperty="Y"
                                From="0" To="-120" Duration="0:0:0.5"
                                AutoReverse="True">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="scaleT"
                                Storyboard.TargetProperty="ScaleX">
                                <SplineDoubleKeyFrame KeyTime="0:0:0.25" Value="0.85"/>
                                <SplineDoubleKeyFrame KeyTime="0:0:0.5"  Value="1.00"/>
                                <SplineDoubleKeyFrame KeyTime="0:0:1.0"  Value="1.00"/>
                                <SplineDoubleKeyFrame KeyTime="0:0:1.05" Value="1.50"/>
                                <SplineDoubleKeyFrame KeyTime="0:0:1.20" Value="1.00"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="scaleT"
                                Storyboard.TargetProperty="ScaleY">
                                <SplineDoubleKeyFrame KeyTime="0:0:0.25" Value="1.20"/>
                                <SplineDoubleKeyFrame KeyTime="0:0:0.5"  Value="1.00"/>
                                <SplineDoubleKeyFrame KeyTime="0:0:1.0"  Value="1.00"/>
                                <SplineDoubleKeyFrame KeyTime="0:0:1.05" Value="0.55"/>
                                <SplineDoubleKeyFrame KeyTime="0:0:1.20" Value="1.00"/>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>
    </Grid>
</Window>
