<Window x:Class="HeadTracking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Head Tracking (Look-at Cursor)" Height="400" Width="400"
        Background="#0A0F1C" MouseMove="Window_MouseMove">
    <Grid>
        <Ellipse Width="120" Height="120" Fill="#FFE0BD"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="headRot" Angle="0"/>
            </Ellipse.RenderTransform>
        </Ellipse>
        <!-- Eyes (offset from center) -->
        <Canvas x:Name="eyeRoot" Width="120" Height="120"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5"
                IsHitTestVisible="False">
            <Ellipse Width="14" Height="14" Fill="#0F172A"
                     Canvas.Left="36" Canvas.Top="48"/>
            <Ellipse Width="14" Height="14" Fill="#0F172A"
                     Canvas.Left="70" Canvas.Top="48"/>
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="eyeOff" X="0" Y="0"/>
            </Canvas.RenderTransform>
        </Canvas>
    </Grid>
    <!--
    // Code-behind (MainWindow.xaml.cs):
    private void Window_MouseMove(object sender, MouseEventArgs e) {
        var p = e.GetPosition(this);
        var cx = ActualWidth  / 2;
        var cy = ActualHeight / 2;
        var dx = p.X - cx;
        var dy = p.Y - cy;
        var ang = Math.Atan2(dy, dx) * 180.0 / Math.PI;
        // Smooth lerp toward target (animated via DoubleAnimation in real use)
        headRot.Angle = ang * 0.15;          // subtle tilt
        eyeOff.X = Math.Max(-6, Math.Min(6, dx * 0.04));
        eyeOff.Y = Math.Max(-4, Math.Min(4, dy * 0.04));
    }
    -->
</Window>
