<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Eye Blink Sequence" Height="220" Width="360" Background="#0A0F1C">
    <Grid>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="eyeL" Width="48" Height="48"
                         Fill="#F1F5F9" Margin="0,0,30,0"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="lidL" ScaleY="1"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse x:Name="eyeR" Width="48" Height="48"
                         Fill="#F1F5F9"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="lidR" ScaleY="1"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </StackPanel>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="lidL"
                                Storyboard.TargetProperty="ScaleY">
                                <LinearDoubleKeyFrame KeyTime="0:0:2.5" Value="1.0"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:2.6" Value="0.05"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:2.75" Value="1.0"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:5.0" Value="1.0"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:5.08" Value="0.05"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:5.16" Value="0.05"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:5.30" Value="1.0"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="lidR"
                                Storyboard.TargetProperty="ScaleY"
                                BeginTime="0:0:0.02">
                                <LinearDoubleKeyFrame KeyTime="0:0:2.5" Value="1.0"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:2.6" Value="0.05"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:2.75" Value="1.0"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:5.0" Value="1.0"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:5.08" Value="0.05"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:5.16" Value="0.05"/>
                                <LinearDoubleKeyFrame KeyTime="0:0:5.30" Value="1.0"/>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>
    </Grid>
</Window>
