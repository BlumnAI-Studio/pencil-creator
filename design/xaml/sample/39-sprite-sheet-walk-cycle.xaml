<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sprite Sheet Walk Cycle" Height="320" Width="480" Background="#0A0F1C">
    <Grid>
        <Border x:Name="charBox" Width="96" Height="96"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                CornerRadius="8" ClipToBounds="True">
            <Border.Background>
                <ImageBrush x:Name="spriteBrush"
                            ImageSource="hero-sprites.png"
                            ViewboxUnits="Absolute"
                            Viewbox="0,0,96,96"
                            Stretch="None"/>
            </Border.Background>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <RectAnimationUsingKeyFrames
                                Storyboard.TargetName="spriteBrush"
                                Storyboard.TargetProperty="Viewbox"
                                Duration="0:0:0.8">
                                <DiscreteRectKeyFrame KeyTime="0:0:0.0" Value="0,0,96,96"/>
                                <DiscreteRectKeyFrame KeyTime="0:0:0.1" Value="96,0,96,96"/>
                                <DiscreteRectKeyFrame KeyTime="0:0:0.2" Value="192,0,96,96"/>
                                <DiscreteRectKeyFrame KeyTime="0:0:0.3" Value="288,0,96,96"/>
                                <DiscreteRectKeyFrame KeyTime="0:0:0.4" Value="384,0,96,96"/>
                                <DiscreteRectKeyFrame KeyTime="0:0:0.5" Value="480,0,96,96"/>
                                <DiscreteRectKeyFrame KeyTime="0:0:0.6" Value="576,0,96,96"/>
                                <DiscreteRectKeyFrame KeyTime="0:0:0.7" Value="672,0,96,96"/>
                            </RectAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>
    </Grid>
</Window>
