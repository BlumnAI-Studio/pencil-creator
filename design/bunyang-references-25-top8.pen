                {
                  "type": "frame",
                  "id": "s3B46",
                  "name": "WPF",
                  "width": "fill_container",
                  "fill": "#0E1014",
                  "cornerRadius": 4,
                  "layout": "vertical",
                  "gap": 16,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "k4B1R",
                      "fill": "#C5A572",
                      "content": "WPF · XAML STORYBOARD",
                      "fontFamily": "Inter",
                      "fontSize": 11,
                      "fontWeight": "600",
                      "letterSpacing": 2.4
                    },
                    {
                      "type": "text",
                      "id": "E8w28",
                      "fill": "#FAF8F4",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "<Storyboard x:Key=\"HeroIn\">\n  <DoubleAnimation Storyboard.TargetName=\"Eyebrow\"\n    Storyboard.TargetProperty=\"Opacity\"\n    From=\"0\" To=\"1\" Duration=\"0:0:0.4\"/>\n  <DoubleAnimation Storyboard.TargetName=\"Headline\"\n    Storyboard.TargetProperty=\"(Clip.Rect.Y)\"\n    From=\"100\" To=\"0\" Duration=\"0:0:1.0\"\n    BeginTime=\"0:0:0.4\">\n    <DoubleAnimation.EasingFunction>\n      <CubicEase EasingMode=\"EaseOut\"/>\n    </DoubleAnimation.EasingFunction>\n  </DoubleAnimation>\n  <DoubleAnimation Storyboard.TargetName=\"GoldLine\"\n    Storyboard.TargetProperty=\"(ScaleTransform.ScaleX)\"\n    From=\"0\" To=\"1\" Duration=\"0:0:0.6\"\n    BeginTime=\"0:0:2.2\"/>\n</Storyboard>",
                      "lineHeight": 1.7,
                      "fontFamily": "Geist Mono",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "HDs64",
                  "name": "CSS-WAAPI",
                  "width": "fill_container",
                  "fill": "#0E1014",
                  "cornerRadius": 4,
                  "layout": "vertical",
                  "gap": 16,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "T2Byk",
                      "fill": "#C5A572",
                      "content": "CSS / WAAPI",
                      "fontFamily": "Inter",
                      "fontSize": 11,
                      "fontWeight": "600",
                      "letterSpacing": 2.4
                    },
                    {
                      "type": "text",
                      "id": "aoLLK",
                      "fill": "#FAF8F4",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "@keyframes mask-up {\n  from { clip-path: inset(100% 0 0 0); }\n  to   { clip-path: inset(0 0 0 0); }\n}\n.eyebrow { animation: fade-up .4s ease both; }\n.headline {\n  animation: mask-up 1s cubic-bezier(.7,0,.3,1) .4s both;\n}\n.subcopy { animation: fade-up .8s ease 1.4s both; }\n.gold-line {\n  transform-origin: left;\n  animation: scale-x .6s cubic-bezier(.7,0,.3,1) 2.2s both;\n}\n@keyframes scale-x { from{transform:scaleX(0)} to{transform:scaleX(1)} }\n.veil { background: url(noise.svg); opacity:.08; }",
                      "lineHeight": 1.7,
                      "fontFamily": "Geist Mono",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
