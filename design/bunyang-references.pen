              "children": [
                {
                  "type": "text",
                  "id": "vujlr",
                  "fill": "#94A3B8",
                  "content": "document.addEventListener('mousemove', e => {",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "500"
                },
                {
                  "type": "text",
                  "id": "loOjM",
                  "fill": "#22D3EE",
                  "content": "  document.querySelectorAll('[data-depth]').forEach(el => {",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "500"
                },
                {
                  "type": "text",
                  "id": "qEsSc",
                  "fill": "#22D3EE",
                  "content": "    const d = parseFloat(el.dataset.depth)",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "500"
                },
                {
                  "type": "text",
                  "id": "InNC4",
                  "fill": "#F8FAFC",
                  "content": "    const x = (e.clientX - innerWidth/2) * d, y = (e.clientY - innerHeight/2) * d",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "500"
                },
                {
                  "type": "text",
                  "id": "bNgom",
                  "fill": "#F8FAFC",
                  "content": "    el.style.transform = `translate(${x}px, ${y}px)` }) })",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "500"
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
