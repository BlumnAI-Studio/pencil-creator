                        {
                          "type": "text",
                          "id": "mQh7T",
                          "fill": "#94A3B8",
                          "content": "document.addEventListener('mousemove', e => {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "500"
                        },
                        {
                          "type": "text",
                          "id": "LCgGy",
                          "fill": "#22D3EE",
                          "content": "  $('[data-depth]').each((i, el) => {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "500"
                        },
                        {
                          "type": "text",
                          "id": "J79deH",
                          "fill": "#22D3EE",
                          "content": "    const d = +el.dataset.depth",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "500"
                        },
                        {
                          "type": "text",
                          "id": "FTNhX",
                          "fill": "#F8FAFC",
                          "content": "    TweenMax.to(el, .6, { x:(e.clientX-w/2)*d, y:(e.clientY-h/2)*d, ease:Power2.easeOut })",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "500"
                        },
                        {
                          "type": "text",
                          "id": "BC8yE",
                          "fill": "#F8FAFC",
                          "content": "  }) })",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "500"
                        }
                      ]
